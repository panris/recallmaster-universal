# RecallMaster Universal Configuration
# Copy this to .env and fill in your values

# OpenAI-compatible Judge API
JUDGE_BASE_URL=https://api.openai.com/v1
JUDGE_API_KEY=sk-your-key-here
JUDGE_MODEL=gpt-4o-mini

# Elasticsearch (optional)
ES_BASE_URL=http://localhost:9200
ES_API_KEY=

# PostgreSQL (optional, for production persistence)
POSTGRES_CONNECTION=jdbc:postgresql://localhost:5432/recallmaster
POSTGRES_USER=recallmaster
POSTGRES_PASSWORD=recallmaster

# H2 database (default, dev mode)
# SPRING_DATASOURCE_URL=jdbc:h2:file:./data/recallmaster

# Application
SERVER_PORT=8080
SPRING_PROFILES_ACTIVE=dev